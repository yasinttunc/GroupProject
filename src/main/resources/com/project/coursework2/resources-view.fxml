        </HBox>

        <Label text="EQUIPMENT"
               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #3D3D3D;"/>

        <HBox spacing="15" fx:id="equipmentContainer">
            <VBox spacing="5" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10;" prefWidth="150">
