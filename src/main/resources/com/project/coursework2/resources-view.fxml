            <VBox spacing="5" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10;" prefWidth="150">
                <Label text="VR Headset 2" style="-fx-font-weight: bold; -fx-text-fill: #3D3D3D;"/>
                <Label text="1650 lohuel" style="-fx-text-fill: #7A7A7A; -fx-font-size: 11px;"/>
                <Button text="Book" style="-fx-background-color: #4AADA8; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;"/>
            </VBox>
            <VBox spacing="5" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10;" prefWidth="150">
                <Label text="Sound Kit 1" style="-fx-font-weight: bold; -fx-text-fill: #3D3D3D;"/>
                <Label text="1000 MBPS Apexo" style="-fx-text-fill: #7A7A7A; -fx-font-size: 11px;"/>
                <Button text="Book" style="-fx-background-color: #4AADA8; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;"/>
            </VBox>
            <VBox spacing="5" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10;" prefWidth="150">
                <Label text="Sound Kit K" style="-fx-font-weight: bold; -fx-text-fill: #3D3D3D;"/>
                <Label text="1760 M5H" style="-fx-text-fill: #7A7A7A; -fx-font-size: 11px;"/>
                <Button text="Book" style="-fx-background-color: #4AADA8; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;"/>
            </VBox>
        </HBox>

    </VBox>
</ScrollPane>
