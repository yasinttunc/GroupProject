<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.project.coursework2.controller.AccountController"
            fitToWidth="true"
            style="-fx-background-color: #FDF6EC;">

    <VBox spacing="20" style="-fx-background-color: #FDF6EC; -fx-padding: 30;">

        <Label text="ACCOUNT"
               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #3D3D3D;"/>

        <HBox spacing="20">

            <!-- Profile -->
            <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10;" prefWidth="300">
                <Label text="PROFILE" style="-fx-font-weight: bold; -fx-text-fill: #3D3D3D;"/>
                <HBox spacing="10">
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="First Name" style="-fx-font-size: 11px; -fx-text-fill: #7A7A7A;"/>
                        <TextField fx:id="firstNameField" promptText="Jasmine"/>
                    </VBox>
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="Last Name" style="-fx-font-size: 11px; -fx-text-fill: #7A7A7A;"/>
                        <TextField fx:id="lastNameField" promptText="Eagles"/>
                    </VBox>
                </HBox>
                <Label text="Email Address" style="-fx-font-size: 11px; -fx-text-fill: #7A7A7A;"/>
                <TextField fx:id="emailField" promptText="email@swansea.ac.uk"/>
                <HBox spacing="10">
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="Fiscal ID" style="-fx-font-size: 11px; -fx-text-fill: #7A7A7A;"/>
                        <TextField fx:id="fiscalIdField" promptText="2244555"/>
                    </VBox>
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="ID" style="-fx-font-size: 11px; -fx-text-fill: #7A7A7A;"/>
                        <TextField fx:id="idField" promptText="2244555"/>
                    </VBox>
                </HBox>
                <Label text="Password" style="-fx-font-size: 11px; -fx-text-fill: #7A7A7A;"/>
                <PasswordField fx:id="passwordField" promptText="••••••••"/>
                <HBox spacing="10">
                    <Button text="Delete Account" onAction="#handleDeleteAccount"
                            style="-fx-background-color: #E8735A; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;"/>
                    <Button text="Edit" onAction="#handleEdit"
                            style="-fx-background-color: #7A7A7A; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;"/>
                    <Button text="Save" onAction="#handleSave"
                            style="-fx-background-color: #4AADA8; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;"/>
                </HBox>
            </VBox>

            <!-- Admin Help Request -->
            <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10;" prefWidth="300">
                <Label text="ADMIN HELP REQUEST" style="-fx-font-weight: bold; -fx-text-fill: #3D3D3D;"/>
                <Label text="Need assistance? Send a message to the admin team."
                       style="-fx-font-size: 11px; -fx-text-fill: #7A7A7A;" wrapText="true"/>
                <Label text="SUBJECT" style="-fx-font-size: 11px; -fx-text-fill: #7A7A7A;"/>
                <ComboBox fx:id="helpSubjectDropdown" promptText="Select a topic" prefWidth="260">
                </ComboBox>
                <Label text="YOUR MESSAGE" style="-fx-font-size: 11px; -fx-text-fill: #7A7A7A;"/>
                <TextArea fx:id="helpMessageField" promptText="Describe your issue or question here..."
                          prefHeight="120" wrapText="true"/>
                <Label fx:id="helpConfirmLabel" text=""
                       style="-fx-text-fill: #4AADA8; -fx-font-size: 11px;"/>
                <HBox spacing="10">
                    <Button text="Clear" onAction="#handleHelpClear"
                            style="-fx-background-color: #7A7A7A; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;"/>
                    <Button text="Submit Request" onAction="#handleHelpSubmit"
                            style="-fx-background-color: #4AADA8; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;"/>
                </HBox>
            </VBox>

        </HBox>

    </VBox>
</ScrollPane>
